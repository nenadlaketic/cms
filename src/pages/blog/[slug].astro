---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const catGradients: Record<string, string> = {
  Saveti: 'linear-gradient(135deg,#1c6b62,#12433f)',
  Estetika: 'linear-gradient(135deg,#c96a44,#a94e2c)',
  Implantologija: 'linear-gradient(135deg,#4a7c8c,#2f5766)',
  Ortodoncija: 'linear-gradient(135deg,#6b7f9e,#3f4f6b)',
};
const bg = catGradients[post.data.kategorija] ?? 'linear-gradient(135deg,#12433f,#1c6b62)';

const allPosts = (await getCollection('blog'))
  .filter(p => p.id !== post.id)
  .sort((a, b) => b.data.datum.valueOf() - a.data.datum.valueOf())
  .slice(0, 3);

const datum = post.data.datum.toLocaleDateString('sr-Latn', { day: 'numeric', month: 'long', year: 'numeric' });
---
<Layout title={post.data.naslov} activePage="blog">

<div style="min-height:100vh;">

  <article style="max-width:760px;margin:0 auto;padding:52px 32px 24px;">
    <a href="/blog" style="display:inline-flex;align-items:center;gap:7px;font-size:14px;font-weight:700;color:#1c6b62;margin-bottom:26px;">← Nazad na blog</a>
    <div style="display:flex;gap:12px;font-size:13px;font-weight:700;color:#c96a44;text-transform:uppercase;letter-spacing:0.04em;margin-bottom:16px;">
      <span>{post.data.kategorija}</span>
      <span style="color:#b7bcb9;">· {post.data.vreme} čitanja</span>
      <span style="color:#b7bcb9;">· {datum}</span>
    </div>
    <h1 style="font-family:Newsreader,serif;font-weight:500;font-size:46px;line-height:1.08;letter-spacing:-0.02em;margin:0 0 24px;color:#12433f;">{post.data.naslov}</h1>
    <div style="display:flex;align-items:center;gap:13px;padding-bottom:8px;">
      <span style="width:46px;height:46px;border-radius:50%;background:linear-gradient(150deg,#1c6b62,#12433f);display:inline-flex;align-items:center;justify-content:center;color:#f7f4ee;font-weight:700;font-size:15px;">MJ</span>
      <div>
        <div style="font-size:15px;font-weight:700;color:#12433f;">Dr Marija Jovanović</div>
        <div style="font-size:13px;color:#6a7772;">Specijalista opšte stomatologije</div>
      </div>
    </div>
  </article>

  <div style="max-width:900px;margin:0 auto;padding:12px 32px 0;">
    {post.data.slika
      ? <img src={post.data.slika} alt={post.data.naslov} style="width:100%;aspect-ratio:16/8;border-radius:26px;object-fit:cover;box-shadow:0 24px 60px rgba(18,67,63,0.14);display:block;" />
      : <div style={`aspect-ratio:16/8;border-radius:26px;background:${bg};box-shadow:0 24px 60px rgba(18,67,63,0.14);`}></div>
    }
  </div>

  <article class="prose" style="max-width:720px;margin:0 auto;padding:44px 32px 24px;">
    <Content />

    <div style="margin-top:44px;padding-top:28px;border-top:1px solid rgba(18,67,63,0.12);display:flex;flex-wrap:wrap;gap:10px;align-items:center;">
      <span style="font-size:13px;font-weight:700;color:#6a7772;text-transform:uppercase;letter-spacing:0.05em;">Teme:</span>
      <span style="background:#fff;border:1px solid rgba(18,67,63,0.12);border-radius:999px;padding:6px 14px;font-size:13px;font-weight:600;color:#12433f;">{post.data.kategorija}</span>
      <span style="background:#fff;border:1px solid rgba(18,67,63,0.12);border-radius:999px;padding:6px 14px;font-size:13px;font-weight:600;color:#12433f;">Nega zuba</span>
    </div>
  </article>

  <section style="max-width:900px;margin:24px auto 0;padding:0 32px 20px;">
    <div style="background:#12433f;border-radius:26px;padding:40px 44px;display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:24px;">
      <div>
        <h3 style="font-family:Newsreader,serif;font-weight:500;font-size:28px;line-height:1.15;margin:0 0 8px;color:#f7f4ee;">Imate pitanje o svom osmehu?</h3>
        <p style="font-size:16px;color:rgba(247,244,238,0.8);margin:0;">Zakažite pregled i porazgovarajte sa našim timom.</p>
      </div>
      <a href="/#zakazivanje" style="background:#c96a44;color:#fff;padding:15px 28px;border-radius:999px;font-size:15px;font-weight:700;white-space:nowrap;">Zakaži termin</a>
    </div>
  </section>

  {allPosts.length > 0 && (
    <section style="max-width:1200px;margin:0 auto;padding:48px 32px 72px;">
      <h3 style="font-family:Newsreader,serif;font-weight:500;font-size:30px;line-height:1.1;letter-spacing:-0.01em;margin:0 0 26px;color:#12433f;">Povezani članci</h3>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;">
        {allPosts.map(p => {
          const pBg = catGradients[p.data.kategorija] ?? 'linear-gradient(135deg,#12433f,#1c6b62)';
          return (
            <a href={`/blog/${p.id}`} style="display:flex;flex-direction:column;background:#fff;border-radius:22px;overflow:hidden;border:1px solid rgba(18,67,63,0.07);color:inherit;">
              {p.data.slika
                ? <img src={p.data.slika} alt={p.data.naslov} style="width:100%;aspect-ratio:16/10;object-fit:cover;display:block;" />
                : <div style={`aspect-ratio:16/10;background:${pBg};`}></div>
              }
              <div style="padding:22px;">
                <div style="display:flex;gap:10px;font-size:12px;font-weight:700;color:#c96a44;text-transform:uppercase;letter-spacing:0.04em;margin-bottom:10px;"><span>{p.data.kategorija}</span><span style="color:#b7bcb9;">· {p.data.vreme}</span></div>
                <h4 style="font-family:Newsreader,serif;font-size:21px;font-weight:500;line-height:1.2;margin:0 0 8px;color:#12433f;">{p.data.naslov}</h4>
                <span style="font-size:14px;font-weight:700;color:#1c6b62;">Pročitaj →</span>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  )}

</div>

<style>
  .prose {
    font-size: 18px;
    line-height: 1.75;
    color: #3a4b47;
  }
  .prose p { margin: 0 0 22px; }
  .prose p:first-child { font-size: 21px; line-height: 1.6; color: #12433f; font-weight: 500; margin-bottom: 28px; }
  .prose h2 { font-family: Newsreader, serif; font-weight: 500; font-size: 30px; line-height: 1.2; letter-spacing: -0.01em; margin: 40px 0 16px; color: #12433f; }
  .prose h3 { font-family: Newsreader, serif; font-weight: 500; font-size: 24px; line-height: 1.2; margin: 30px 0 12px; color: #12433f; }
  .prose ul { margin: 0 0 22px; padding-left: 22px; }
  .prose ol { margin: 0 0 22px; padding-left: 22px; }
  .prose li { margin-bottom: 10px; }
  .prose strong { color: #12433f; font-weight: 700; }
  .prose blockquote { background: #e4efe9; border-left: 3px solid #1c6b62; border-radius: 0 16px 16px 0; padding: 22px 26px; margin: 32px 0; }
  .prose blockquote p { margin: 0; font-size: 18px; line-height: 1.6; color: #12433f; font-style: italic; font-family: Newsreader, serif; }
</style>

</Layout>
